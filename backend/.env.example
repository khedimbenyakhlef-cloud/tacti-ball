# ─────────────────────────────────────────────────────────────
#  TACTI-BALL PRO v3 — Variables d'environnement
#  Copier ce fichier en ".env" et remplir les valeurs
# ─────────────────────────────────────────────────────────────

# Clés Groq API (obligatoire — https://console.groq.com)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_2=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL externe de votre déploiement Render (pour keep-alive)
# Format : https://tactiball-pro-v3.onrender.com
RENDER_EXTERNAL_URL=https://tactiball-pro-v3.onrender.com

# Port (Render l'injecte automatiquement — ne pas changer)
PORT=10000
